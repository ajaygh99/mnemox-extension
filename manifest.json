{
  "manifest_version": 3,
  "name": "Mnemox",
  "version": "1.0.0",
  "description": "Real-time prompt scorer and token counter. Works on any site. Instant coaching panel with rule breakdown and improved prompt suggestions. Zero external API dependencies.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "scoring/rules.js",
        "scoring/tokenizer.js",
        "ui/badge.js",
        "ui/pageWorld.js",
        "adapters/chatgpt.js",
        "adapters/claude.js",
        "adapters/gemini.js",
        "adapters/registry.js",
        "ui/coach.js",
        "scoring/suggester.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mnemox"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "homepage_url": "https://github.com/ajjukak123/mnemox-extension"
}
